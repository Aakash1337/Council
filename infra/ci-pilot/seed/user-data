#cloud-config
hostname: ci-pilot
manage_etc_hosts: true
users:
  - name: runner
    groups: [sudo]
    shell: /bin/bash
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    lock_passwd: true
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEQHJChE2RTU6ynb8U7I9JL4T5GTESTECGuHl6kAjZ3/ council-ci-pilot
ssh_pwauth: false
package_update: true
packages: [openssh-server]
runcmd:
  - systemctl enable ssh
  - systemctl start ssh
